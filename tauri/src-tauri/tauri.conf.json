{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desk Watcher",
  "version": "0.1.0",
  "identifier": "com.deskwatcher.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../../frontend run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix ../../frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Desk Watcher",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "app"],
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/watcher/",
      "binaries/api/"
    ],
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "Camera-driven desk activity dashboard",
    "longDescription": "Runs a background watcher on your webcam and shows a live dashboard of desk activity — sips, phone use, breaks, lunch.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
