---
// Paired Windows + macOS download buttons with an (i) info affordance whose
// hover/focus tooltip carries the unsigned-installer / Gatekeeper caveats.
// Used in both the hero and the "get it" section so the markup lives once.
//
// hrefs go through /api/download?os=… (site/api/download.js), which resolves
// the latest release asset at request time — no per-release link edits.
interface Props {
  winHref: string;
  macHref: string;
  note: string;
}
const { winHref, macHref, note } = Astro.props;
---

<div class="flex items-center gap-2">
  <a
    href={winHref}
    class="bg-amber-600 text-ink-950 hover:bg-amber-500 transition-colors px-4 py-2 text-2xs uppercase tracking-[0.16em] font-semibold inline-flex items-center gap-2"
  >
    {/* Windows 4-pane logo. currentColor → inherits button text color. */}
    <svg viewBox="0 0 88 88" class="w-3.5 h-3.5" fill="currentColor" aria-hidden="true">
      <path d="M0 12.4 36 7.5v34.9H0zM40.3 6.9 88 0v42.2H40.3zM0 46.6h36v34.9L0 76.6zM40.3 46.6H88V88l-47.7-6.7z"/>
    </svg>
    download <span class="text-ink-950/70 normal-case tracking-normal font-normal">- windows</span>
  </a>
  <a
    href={macHref}
    class="text-ink-100 hover:text-ink-100 hover:bg-ink-850 transition-colors px-4 py-2 text-2xs uppercase tracking-[0.16em] font-semibold border border-ink-600 inline-flex items-center gap-2"
  >
    {/* Apple logo. currentColor → inherits button text color. */}
    <svg viewBox="0 0 384 512" class="w-3.5 h-3.5" fill="currentColor" aria-hidden="true">
      <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
    </svg>
    download <span class="text-ink-100/60 normal-case tracking-normal font-normal">- macos</span>
  </a>
  {/* Info affordance — the first-launch/unsigned caveats live here on */}
  {/* hover/focus instead of a paragraph, to keep the CTA row uncluttered. */}
  <span class="group relative inline-flex" tabindex="0" role="note" aria-label={note}>
    <svg viewBox="0 0 24 24" class="w-4 h-4 text-ink-500 hover:text-ink-300 transition-colors cursor-help" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="12" cy="12" r="9" />
      <line x1="12" y1="11" x2="12" y2="16" />
      <circle cx="12" cy="7.5" r="0.5" fill="currentColor" stroke="none" />
    </svg>
    <span
      class="pointer-events-none absolute left-0 top-full mt-2 w-72 z-10 rounded border border-ink-700 bg-ink-900 px-3 py-2 text-2xs lowercase leading-relaxed text-ink-300 opacity-0 translate-y-1 transition-all duration-150 group-hover:opacity-100 group-hover:translate-y-0 group-focus:opacity-100 group-focus:translate-y-0"
    >{note}</span>
  </span>
</div>
